# Plaid API keys — get yours at https://dashboard.plaid.com
SENTINEL_PLAID_CLIENT_ID=your_client_id_here
SENTINEL_PLAID_SECRET=your_secret_here
SENTINEL_PLAID_ENV=sandbox  # sandbox, development, or production

# Coinbase API keys — get yours at coinbase.com/settings/api
# Required permissions: wallet:accounts:read, wallet:transactions:read
SENTINEL_COINBASE_API_KEY=your_coinbase_api_key_here
SENTINEL_COINBASE_API_SECRET=your_coinbase_api_secret_here
